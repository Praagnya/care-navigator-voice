# ── Application ───────────────────────────────────────────────────────────────
APP_ENV=development          # development | staging | production
APP_SECRET_KEY=change-me-in-production
LOG_LEVEL=INFO

# ── Database ───────────────────────────────────────────────────────────────────
# Async URL used by SQLAlchemy at runtime
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/care_navigator
# Sync URL used by Alembic for schema migrations
DATABASE_URL_SYNC=postgresql+psycopg2://postgres:postgres@localhost:5432/care_navigator
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# ── LLM ───────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# ── AWS ───────────────────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET_NAME=care-navigator-data

# ── Observability ─────────────────────────────────────────────────────────────
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# ── CMS Data Pipeline ─────────────────────────────────────────────────────────
CMS_API_BASE_URL=https://data.cms.gov/resource
CMS_HOSPITAL_DATASET_ID=xubh-q36u

# ── Pipeline Versioning ───────────────────────────────────────────────────────
PIPELINE_VERSION=0.1.0
SCHEMA_VERSION=1.0
